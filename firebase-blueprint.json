{
  "entities": {
    "Generation": {
      "title": "Generation",
      "description": "Saved AI tool content generations",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "toolType": { "type": "string" },
        "inputs": { "type": "object" },
        "result": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "toolType", "inputs", "result", "createdAt"]
    },
    "ContactSubmission": {
      "title": "ContactSubmission",
      "description": "Contact Form message submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "generations/{generationId}": {
      "schema": "Generation",
      "description": "User generated contents with the toolset"
    },
    "contact_submissions/{submissionId}": {
      "schema": "ContactSubmission",
      "description": "Direct inquiries from visitors and potential creators"
    }
  }
}
